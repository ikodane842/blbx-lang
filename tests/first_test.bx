    }
)

for(
    array,
    (__) => {
        if(
            (__.elem()).eq("three"),
            () => { __.continue() },
            () => { print((__.elem()).type()) }
        )
    }
)

while(
    (array.length()).eq(4),
    () => {
        print("hello world")
    }
)

